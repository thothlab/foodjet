# FoodJet Code Owners
# Each line is a file pattern followed by one or more owners.
# Order matters -- last matching pattern takes precedence.

# Default: tech lead owns everything not covered below
*                       @tech-lead

# Backend
/apps/backend/          @backend-team

# Frontend apps
/apps/mini-app/         @frontend-team
/apps/admin/            @frontend-team
/apps/courier/          @frontend-team

# Shared packages -- requires approval from both backend and frontend leads
/packages/shared/       @backend-lead @frontend-lead

# Documentation
/docs/                  @tech-lead
