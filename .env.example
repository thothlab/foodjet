# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodjet

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Mini App URL (used for Telegram bot Menu Button and inline keyboards)
MINI_APP_URL=http://localhost:5173
